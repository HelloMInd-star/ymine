{
  "lab_name": "MindSpeak Embedding Lab",
  "lab_code": "MS-Lab",
  "version": "V1.0-Batch1",
  "game_os_version": "V3.0",
  "peer_lab": "MoodMind 金融向量实验室",
  "upper_console": "几何心智空间全域大模型算力错峰调度与二进制底层执行底座中控台",
  "created_at": "2026-07-21",
  "storage_tiers": {
    "trash": {
      "path": "mslab_trash_db",
      "desc": "无效噪声库",
      "watermark_alarm": 0.95,
      "auto_cleanup": true
    },
    "buffer": {
      "path": "mslab_buffer_db",
      "desc": "临时缓冲向量库",
      "watermark_alarm": 0.85,
      "auto_cleanup": false
    },
    "normal": {
      "path": "mslab_normal_db",
      "desc": "常规业务向量库",
      "watermark_alarm": 0.80,
      "auto_cleanup": false
    },
    "knowledge": {
      "path": "mslab_knowledge_db",
      "desc": "定型高价值知识库",
      "watermark_alarm": 0.90,
      "auto_cleanup": false
    }
  },
  "thresholds": {
    "breakeven": 0.48,
    "steady_state": 0.50,
    "fuse_line": 0.68,
    "default_similarity": 0.72,
    "bit_utilization_target": 0.85,
    "precision_degrade_alarm": 0.05
  },
  "encryption": {
    "algorithm": "AES-256-GCM",
    "key_file": "mslab_security/mslab.key",
    "enabled": true
  },
  "permissions": {
    "operator": {
      "level": 1,
      "label": "普通操作员",
      "can": ["view_dashboard", "basic_search", "view_billing"]
    },
    "architect": {
      "level": 2,
      "label": "架构审核",
      "can": ["view_dashboard", "basic_search", "view_billing",
              "adjust_threshold", "tier_mgmt", "audit_log"]
    },
    "admin": {
      "level": 3,
      "label": "最高管理员",
      "can": ["view_dashboard", "basic_search", "view_billing",
              "adjust_threshold", "tier_mgmt", "audit_log",
              "precision_config_128bit_entry"]
    }
  },
  "red_lines": [
    "禁止搭建通用应用题底层数学求解函数库",
    "禁止完整实现128bit高精度向量运算，仅预留接口",
    "禁止编写KMP底层匹配源码，只接收最终匹配分值",
    "禁止开发算力调度底层博弈算法，仅做上报和指令接收外壳",
    "禁止硬编码私有风控公式、金融估值深层算子",
    "程序不能自主生成新方程，仅可调用预设固定模板",
    "前端可视化只做展示，禁止嵌入底层数理运算逻辑"
  ]
}
