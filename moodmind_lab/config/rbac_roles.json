{
  "roles": {
    "admin": {
      "name": "超级管理员",
      "color": "#ff4757",
      "permissions": [
        "view_all",
        "edit_config",
        "manage_users",
        "view_private_dims",
        "view_risk_formula",
        "push_to_mslab",
        "manage_alerts",
        "view_audit_logs",
        "billing_admin"
      ],
      "description": "实验室最高权限，可访问所有模块和私有内核接口"
    },
    "quant": {
      "name": "量化研究员",
      "color": "#9b59b6",
      "permissions": [
        "view_vectors",
        "view_lighting",
        "view_kmp_scores",
        "view_risk_status",
        "run_backtest",
        "view_billing"
      ],
      "description": "可查看向量、光照、KMP分值、风控状态，但无法修改配置和查看公式"
    },
    "operator": {
      "name": "运维操作员",
      "color": "#3498db",
      "permissions": [
        "view_dashboard",
        "view_storage",
        "view_compute",
        "manage_alerts",
        "view_audit_logs",
        "restart_services"
      ],
      "description": "负责运维监控，查看存储、算力、告警、审计，无法查看金融向量私有维度"
    },
    "viewer": {
      "name": "只读访客",
      "color": "#2ecc71",
      "permissions": [
        "view_public_dashboard",
        "view_basic_stats"
      ],
      "description": "仅可查看公开大盘基础统计数据"
    }
  },
  "default_role": "viewer"
}
